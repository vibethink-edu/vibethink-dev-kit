{
  "$schema": "VIBETHINK_KDD_MEMORY_FRESHNESS_V1",
  "_about": "L3 binding for KDD memory freshness. DevKit verifies source/index freshness; the consuming repo declares concrete Graphify/Engram/other refresh commands and artifacts.",
  "manifestPath": "docs/knowledge/.kdd-memory-manifest.json",
  "sourceRoots": ["docs/knowledge", "doc/decisions", "docs/features"],
  "sourceExtensions": [".md", ".json", ".yaml", ".yml"],
  "sourcePackStatuses": ["accepted"],
  "maxManifestAgeDays": 14,
  "knowledgeMemoryAdapter": {
    "name": "vibethink-default",
    "engines": ["engram", "graphify"],
    "sourceOfTruth": "versioned-markdown"
  },
  "artifactCache": {
    "mode": "git-common-dir"
  },
  "indexes": [
    {
      "name": "graphify",
      "required": true,
      "artifacts": ["graphify-out/graph.json"],
      "refreshCommand": "graphify update docs/knowledge --no-viz",
      "requireArtifactNewerThanSources": true
    },
    {
      "name": "engram",
      "required": true,
      "artifacts": [".engram/facts.json"],
      "refreshCommand": "engram ingest docs/knowledge",
      "requireArtifactNewerThanSources": true
    }
  ]
}
